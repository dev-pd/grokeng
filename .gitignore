# Main Project .gitignore (grokeng/)

# Environment files
.env
.env.local
.env.*.local

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker volumes (if you want to ignore them)
# Uncomment the lines below if you don't want to persist Docker data
# mysql_data/
# redis_data/

# Temporary files
tmp/
temp/
.tmp/

# Backup files
*.backup
*.bak

# Compressed files
*.zip
*.tar.gz
*.rar

# Documentation builds
docs/_build/
