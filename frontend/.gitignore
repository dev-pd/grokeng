# Frontend .gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Production builds
dist/
build/
*.tgz
*.tar.gz

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Vite
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Testing
coverage/
.nyc_output
*.lcov

# Storybook build outputs
storybook-static/

# TypeScript
*.tsbuildinfo

# ESLint cache
.eslintcache

# Parcel cache
.cache/
.parcel-cache/

# Next.js (if used in future)
.next/

# Nuxt.js (if used in future)
.nuxt/

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Temporary folders
tmp/
temp/
